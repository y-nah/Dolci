<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dolci – Login / Sign Up</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              pink: {
                light: "#fde8ef",
                mid: "#f9c4d4",
                deep: "#e8839f",
                dark: "#c95c7a",
              },
              cream: "#fff8f9",
              rose: {
                text: "#2d1a20",
                mid: "#6b4352",
                muted: "#b07a8e",
              },
            },
            fontFamily: {
              display: ['"Playfair Display"', "Georgia", "serif"],
              body: ['"DM Sans"', "system-ui", "sans-serif"],
            },
            borderRadius: {
              "4xl": "2rem",
              "5xl": "2.5rem",
            },
          },
        },
      };
    </script>

    <style>
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: "DM Sans", system-ui, sans-serif;
      }
      .font-display {
        font-family: "Playfair Display", Georgia, serif;
      }
      .tab-active {
        background-color: #c95c7a;
        color: #fff;
      }
      .form-panel {
        display: none;
      }
      .form-panel.active {
        display: block;
      }
      .input-field {
        transition: box-shadow 0.2s ease, border-color 0.2s ease;
      }
      .input-field:focus {
        border-color: #c95c7a;
        box-shadow: 0 0 0 3px rgba(201, 92, 122, 0.15);
      }
      .shake {
        animation: shake 0.35s ease;
      }
      @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-6px); }
        75% { transform: translateX(6px); }
      }
    </style>
  </head>

  <body class="bg-cream text-rose-text">
    <nav
      class="sticky top-0 z-50 bg-cream/90 backdrop-blur-md border-b border-pink-mid"
    >
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center gap-8">
        <a
          href="index.html"
          class="font-display text-2xl font-bold text-pink-dark mr-auto"
          >🎀 Dolci</a
        >

        <ul class="hidden md:flex gap-8">
          <li>
            <a
              href="index.html"
              class="text-sm font-medium text-rose-mid hover:text-pink-dark transition-colors"
              >Home</a
            >
          </li>
          <li>
            <a
              href="index.html#about"
              class="text-sm font-medium text-rose-mid hover:text-pink-dark transition-colors"
              >About</a
            >
          </li>
          <li>
            <a
              href="menu.html"
              class="text-sm font-medium text-rose-mid hover:text-pink-dark transition-colors"
              >Menu</a
            >
          </li>
          <li>
            <a
              href="index.html#contact"
              class="text-sm font-medium text-rose-mid hover:text-pink-dark transition-colors"
              >Contact</a
            >
          </li>
        </ul>

        <a
          href="customize.html"
          class="inline-flex items-center justify-center text-sm font-semibold px-5 py-2 rounded-full bg-pink-dark text-white shadow-lg shadow-pink-dark/20 hover:bg-[#b54d6a] hover:-translate-y-0.5 transition-all whitespace-nowrap"
        >
          Order Now
        </a>

        <button id="nav-toggle" class="md:hidden text-pink-dark text-2xl">
          ☰
        </button>
      </div>

      <div
        id="mobile-menu"
        class="hidden md:hidden px-6 pb-4 flex flex-col gap-4 border-t border-pink-mid bg-cream"
      >
        <a href="index.html" class="text-sm text-rose-mid font-medium py-1">Home</a>
        <a href="index.html#about" class="text-sm text-rose-mid font-medium py-1">About</a>
        <a href="menu.html" class="text-sm text-rose-mid font-medium py-1">Menu</a>
        <a href="index.html#contact" class="text-sm text-rose-mid font-medium py-1">Contact</a>
      </div>
    </nav>

    <section class="bg-gradient-to-br from-pink-light via-[#fef0f4] to-cream min-h-[80vh] flex items-center">
      <div class="max-w-md mx-auto px-6 py-16 w-full">
        <div class="text-center mb-8">
          <p class="text-xs font-semibold tracking-[3px] uppercase text-pink-deep mb-3">
            Welcome back
          </p>
          <h1 class="font-display font-bold text-4xl text-rose-text">
            Dolci Account
          </h1>
        </div>

        <div class="bg-white rounded-4xl shadow-lg shadow-pink-deep/10 p-8">
          <!-- Tabs -->
          <div class="flex bg-pink-light rounded-full p-1 mb-8">
            <button
              id="tab-login"
              class="flex-1 py-2 rounded-full text-sm font-semibold transition-colors tab-active"
            >
              Login
            </button>
            <button
              id="tab-signup"
              class="flex-1 py-2 rounded-full text-sm font-semibold transition-colors text-rose-mid"
            >
              Sign Up
            </button>
          </div>

          <!-- Login form -->
          <form id="login-form" class="form-panel active space-y-4">
            <div>
              <label class="text-xs font-medium text-rose-mid mb-1 block">Email</label>
              <input
                type="email"
                id="login-email"
                required
                placeholder="you@example.com"
                class="input-field w-full px-4 py-3 rounded-2xl border border-pink-mid outline-none text-sm"
              />
            </div>
            <div>
              <label class="text-xs font-medium text-rose-mid mb-1 block">Password</label>
              <input
                type="password"
                id="login-password"
                required
                minlength="6"
                placeholder="••••••••"
                class="input-field w-full px-4 py-3 rounded-2xl border border-pink-mid outline-none text-sm"
              />
            </div>
            <p id="login-error" class="hidden text-xs text-red-500"></p>
            <button
              type="submit"
              class="w-full py-3 rounded-full bg-pink-dark text-white text-sm font-semibold hover:bg-[#b54d6a] hover:-translate-y-0.5 transition-all shadow-lg shadow-pink-dark/20"
            >
              Log In
            </button>
            <p class="text-center text-xs text-rose-muted">
              Don't have an account?
              <button type="button" id="switch-to-signup" class="text-pink-dark font-semibold">Sign up</button>
            </p>
          </form>

          <!-- Signup form -->
          <form id="signup-form" class="form-panel space-y-4">
            <div>
              <label class="text-xs font-medium text-rose-mid mb-1 block">Full Name</label>
              <input
                type="text"
                id="signup-name"
                required
                placeholder="Your name"
                class="input-field w-full px-4 py-3 rounded-2xl border border-pink-mid outline-none text-sm"
              />
            </div>
            <div>
              <label class="text-xs font-medium text-rose-mid mb-1 block">Email</label>
              <input
                type="email"
                id="signup-email"
                required
                placeholder="you@example.com"
                class="input-field w-full px-4 py-3 rounded-2xl border border-pink-mid outline-none text-sm"
              />
            </div>
            <div>
              <label class="text-xs font-medium text-rose-mid mb-1 block">Contact Number</label>
              <input
                type="tel"
                id="signup-contact"
                required
                pattern="[0-9+\-\s]{7,15}"
                placeholder="09XXXXXXXXX"
                class="input-field w-full px-4 py-3 rounded-2xl border border-pink-mid outline-none text-sm"
              />
            </div>
            <div>
              <label class="text-xs font-medium text-rose-mid mb-1 block">Password</label>
              <input
                type="password"
                id="signup-password"
                required
                minlength="6"
                placeholder="At least 6 characters"
                class="input-field w-full px-4 py-3 rounded-2xl border border-pink-mid outline-none text-sm"
              />
            </div>
            <p id="signup-error" class="hidden text-xs text-red-500"></p>
            <button
              type="submit"
              class="w-full py-3 rounded-full bg-pink-dark text-white text-sm font-semibold hover:bg-[#b54d6a] hover:-translate-y-0.5 transition-all shadow-lg shadow-pink-dark/20"
            >
              Create Account
            </button>
            <p class="text-center text-xs text-rose-muted">
              Already have an account?
              <button type="button" id="switch-to-login" class="text-pink-dark font-semibold">Log in</button>
            </p>
          </form>
        </div>
      </div>
    </section>

    <footer id="contact" class="bg-rose-text text-white/70 pt-14 pb-0">
      <div
        class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row gap-12 pb-12 border-b border-white/10"
      >
        <div class="flex-1">
          <h3 class="font-display text-xl text-white mb-2">🎀 Dolci</h3>
          <p class="text-xs opacity-60">A taste of sweet.</p>
        </div>

        <div class="flex gap-12 flex-wrap">
          <div>
            <h4
              class="text-xs font-semibold text-white uppercase tracking-widest mb-4"
            >
              Shop
            </h4>
            <ul class="space-y-2 text-xs">
              <li><a href="#" class="hover:text-pink-deep transition-colors cursor-default">Cakes</a></li>
              <li><a href="#" class="hover:text-pink-deep transition-colors cursor-default">Cookies</a></li>
              <li><a href="#" class="hover:text-pink-deep transition-colors cursor-default">Gift Boxes</a></li>
            </ul>
          </div>
          <div>
            <h4
              class="text-xs font-semibold text-white uppercase tracking-widest mb-4"
            >
              Info
            </h4>
            <ul class="space-y-2 text-xs">
              <li><a href="#" class="hover:text-pink-deep transition-colors cursor-default">About Us</a></li>
              <li><a href="#" class="hover:text-pink-deep transition-colors cursor-default">Blog</a></li>
              <li><a href="#" class="hover:text-pink-deep transition-colors cursor-default">FAQ</a></li>
            </ul>
          </div>
          <div>
            <h4
              class="text-xs font-semibold text-white uppercase tracking-widest mb-4"
            >
              Connect
            </h4>
            <ul class="space-y-2 text-xs">
              <li><a href="#" class="hover:text-pink-deep transition-colors cursor-default">Instagram</a></li>
              <li><a href="#" class="hover:text-pink-deep transition-colors cursor-default">Facebook</a></li>
              <li><a href="#" class="hover:text-pink-deep transition-colors cursor-default">TikTok</a></li>
            </ul>
          </div>
        </div>
      </div>

      <div class="max-w-6xl mx-auto px-6 py-5 text-center text-xs opacity-40">
        © 2026 Dolci. Made with 🍓 and lots of butter.
      </div>
    </footer>

    <script>
      const toggle = document.getElementById("nav-toggle");
      const menu = document.getElementById("mobile-menu");
      toggle.addEventListener("click", () => menu.classList.toggle("hidden"));

      const tabLogin = document.getElementById("tab-login");
      const tabSignup = document.getElementById("tab-signup");
      const loginForm = document.getElementById("login-form");
      const signupForm = document.getElementById("signup-form");

      function showLogin() {
        tabLogin.classList.add("tab-active");
        tabLogin.classList.remove("text-rose-mid");
        tabSignup.classList.remove("tab-active");
        tabSignup.classList.add("text-rose-mid");
        loginForm.classList.add("active");
        signupForm.classList.remove("active");
      }

      function showSignup() {
        tabSignup.classList.add("tab-active");
        tabSignup.classList.remove("text-rose-mid");
        tabLogin.classList.remove("tab-active");
        tabLogin.classList.add("text-rose-mid");
        signupForm.classList.add("active");
        loginForm.classList.remove("active");
      }

      tabLogin.addEventListener("click", showLogin);
      tabSignup.addEventListener("click", showSignup);
      document.getElementById("switch-to-signup").addEventListener("click", showSignup);
      document.getElementById("switch-to-login").addEventListener("click", showLogin);

      // --- Demo auth logic using localStorage as a stand-in for a real backend ---
      // Replace this with a real API call (fetch to your server) when you have a backend.

      const loginErrorEl = document.getElementById("login-error");
      const signupErrorEl = document.getElementById("signup-error");

      function showError(el, msg) {
        el.textContent = msg;
        el.classList.remove("hidden");
        el.closest("form").classList.add("shake");
        setTimeout(() => el.closest("form").classList.remove("shake"), 350);
      }

      signupForm.addEventListener("submit", (e) => {
        e.preventDefault();
        signupErrorEl.classList.add("hidden");

        const name = document.getElementById("signup-name").value.trim();
        const email = document.getElementById("signup-email").value.trim().toLowerCase();
        const contact = document.getElementById("signup-contact").value.trim();
        const password = document.getElementById("signup-password").value;

        const users = JSON.parse(localStorage.getItem("dolci-users") || "{}");

        if (users[email]) {
          showError(signupErrorEl, "An account with this email already exists.");
          return;
        }

        users[email] = { name, contact, password };
        localStorage.setItem("dolci-users", JSON.stringify(users));
        localStorage.setItem("dolci-current-user", email);

        // Redirect to the page a logged-in user should land on
        window.location.href = "index.html";
      });

      loginForm.addEventListener("submit", (e) => {
        e.preventDefault();
        loginErrorEl.classList.add("hidden");

        const email = document.getElementById("login-email").value.trim().toLowerCase();
        const password = document.getElementById("login-password").value;

        const users = JSON.parse(localStorage.getItem("dolci-users") || "{}");
        const user = users[email];

        if (!user || user.password !== password) {
          showError(loginErrorEl, "Incorrect email or password.");
          return;
        }

        localStorage.setItem("dolci-current-user", email);

        // Redirect to the page a logged-in user should land on
        window.location.href = "index.html";
      });
    </script>
  </body>
</html>
